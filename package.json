{
	"name": "eslint-config-iamnapo",
	"version": "44.0.1",
	"description": "ESLint shareable config for iamnapo’s coding style",
	"license": "MIT",
	"repository": "github:iamnapo/eslint-config-iamnapo",
	"homepage": "https://github.com/iamnapo/eslint-config-iamnapo#readme",
	"bugs": "https://github.com/iamnapo/eslint-config-iamnapo/issues",
	"author": "Napoleon-Christos Oikonomou <Napoleonoikon@gmail.com> (https://iamnapo.me)",
	"type": "module",
	"exports": {
		".": "./index.js"
	},
	"engines": {
		"node": ">=24"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.10.0"
		}
	},
	"publishConfig": {
		"provenance": true
	},
	"scripts": {
		"lint": "eslint --cache",
		"test": "pnpm lint && node test/run.js"
	},
	"files": [
		"configs",
		"index.js"
	],
	"keywords": [
		"eslint",
		"eslintrc",
		"eslintconfig",
		"config",
		"iamnapo",
		"styleguide",
		"react",
		"javascript",
		"typescript"
	],
	"dependencies": {
		"@eslint-react/eslint-plugin": "^5.11.3",
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-import-x": "^4.17.1",
		"eslint-plugin-jsx-a11y-x": "^0.2.0",
		"eslint-plugin-perfectionist": "^5.10.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-unicorn": "^71.1.0",
		"globals": "^17.7.0",
		"typescript-eslint": "^8.63.0"
	},
	"devDependencies": {
		"eslint": "^10.6.0",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"eslint": "^10.0.0",
		"typescript": "^6.0.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	}
